    "help.article.canvas.body1": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اللوحة الرئيسية هي مساحة عملك غير المحدودة. كل عقدة تمثل جزءاً من مشروعك — إعدادات، تطبيق مصغر، أو لوحة فرعية."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your home canvas is an infinite workspace. Each node represents part of your project — settings, a mini-app, or a nested canvas."
          }
        }
      }
    },
    "help.article.canvas.body2": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اسحب للتنقل، قرّب للتركيز، واضغط على العقدة لفتح ما تحتويه."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Drag to pan, pinch to zoom, and tap a node to open what it contains."
          }
        }
      }
    },
    "help.article.canvas.subtitle": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pan, zoom, and organize your spatial workspace"
